{
  "name": "sigma-avatars-monorepo",
  "private": true,
  "workspaces": [
    "packages/*",
    "demo"
  ],
  "scripts": {
    "dev": "cd demo && bun dev",
    "build": "bun run build:lib && bun run build:demo",
    "build:lib": "cd packages/sigma-avatars && bun run build",
    "build:demo": "cd demo && bun run build",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "test": "bun test"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.5",
    "typescript": "~5.9.3"
  }
}